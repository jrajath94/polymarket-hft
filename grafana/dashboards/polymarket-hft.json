{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "PnL Over Time ($)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "axisLabel": "USD"
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hft_pnl_total_usd",
          "legendFormat": "Total PnL",
          "refId": "A"
        },
        {
          "expr": "hft_pnl_realized_usd",
          "legendFormat": "Realized PnL",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Fill Rate %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(hft_orders_filled_total[5m]) / rate(hft_orders_placed_total[5m]) * 100",
          "legendFormat": "Fill Rate",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active Positions",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hft_active_positions",
          "legendFormat": "Positions",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate by Type",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(hft_errors_total[5m])",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Order Latency (Signal to Fill)",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(hft_order_latency_ms_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(hft_order_latency_ms_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(hft_order_latency_ms_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Strategy Performance",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "PnL" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }]
          }
        ]
      },
      "targets": [
        {
          "expr": "hft_strategy_pnl_usd",
          "legendFormat": "{{strategy}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "strategy": "Strategy",
              "Value": "PnL"
            }
          }
        }
      ]
    },
    {
      "title": "Orders per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(hft_orders_placed_total[1m])",
          "legendFormat": "Orders/s",
          "refId": "A"
        },
        {
          "expr": "rate(hft_orders_filled_total[1m])",
          "legendFormat": "Fills/s",
          "refId": "B"
        }
      ]
    },
    {
      "title": "WebSocket Health",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hft_ws_connected",
          "legendFormat": "Connected (1=yes)",
          "refId": "A"
        },
        {
          "expr": "rate(hft_ws_messages_total[1m])",
          "legendFormat": "Messages/s",
          "refId": "B"
        },
        {
          "expr": "rate(hft_ws_reconnects_total[5m])",
          "legendFormat": "Reconnects/5m",
          "refId": "C"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["polymarket", "hft", "trading"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Polymarket HFT Engine",
  "uid": "polymarket-hft-main",
  "version": 1
}
