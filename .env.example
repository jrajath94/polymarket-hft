# Authentication
PRIVATE_KEY=0x...your_l1_wallet_private_key_hex
POLY_API_KEY=your_l2_api_key
POLY_PASSPHRASE=your_l2_passphrase
POLY_ADDRESS=your_l2_wallet_address

# Market Data
CLOB_API_URL=https://clob.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com
DATA_API_URL=https://data-api.polymarket.com

# RPC (for EIP-712 signing simulation)
POLYGON_RPC_URL=https://polygon-rpc.com

# Config
APP_CONFIG=development
RUST_LOG=info

# Risk Parameters (overrides defaults in config/default.toml)
MAX_DAILY_DRAWDOWN=0.1
MAX_POSITION_SIZE=0.05
KELLY_FRACTION=0.25

# Monitoring
PROMETHEUS_LISTEN=127.0.0.1:9090
